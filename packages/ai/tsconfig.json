{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@workspace/ai/*": ["./src/*"]
    }
  },
  "include": ["src", "vitest.config.ts", "eslint.config.ts"],
  "exclude": ["node_modules", "dist"]
}
